# 复制为 .env。策略参数见 quant/settings.py 内 class D 与 SP_* / LEV5_* 环境变量覆盖。

# --- 邮件通知（升级/崩溃/日报）---
NOTIFY_SMTP_HOST=smtp.qq.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=           # 你的 QQ 邮箱地址（如 123456@qq.com）
NOTIFY_SMTP_PASS=           # QQ 邮箱授权码（非登录密码，在QQ邮箱设置→账户→生成授权码）
NOTIFY_TO=1240954013@qq.com

# --- 欧易（仅线性永续）---
OKX_REST_URL=https://www.okx.com
INST_ID=ETH-USDT-SWAP
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_SIMULATED=0
OKX_WS_PROXY=

# --- 策略 ---
STRAT_LIVE=0
STRAT_MODE=grid_pro
# fixed: only grid_pro is supported
STRAT_DATA_SOURCE=ws

# --- 风控（STRAT_LIVE=1 必配）---
RISK_ENABLED=1
RISK_MAX_NOTIONAL_USDT=120
# 单笔 base 上限；永续：张数 × ctVal 换算为 base 后比较
RISK_MAX_ORDER_BASE=0.02

STRAT_ORDER_NOTIONAL_USDT_MIN=25
STRAT_ORDER_NOTIONAL_USDT_MAX=35
STRAT_ORDER_TYPE=limit

# lev5：Runner 层对 features_json.net_edge_bps 的下限（bps），0=关闭；与策略内 LEV5_MIN_NET_EDGE_BPS 独立
# LEV5_RUNNER_FEE_GATE_MIN_NET_EDGE_BPS=0

# 已设置 RISK_MAX_CORR_NOTIONAL_USDT 时：额外拉挂单同步同向敞口（秒），0=关闭
# RISK_CORR_RESYNC_INTERVAL_SEC=18
# 无 USDT 可用余额快照时拦截开仓预检（保守；余额 API 须稳定）
# RISK_MARGIN_PRECHECK_STRICT=0

# STRAT_INVENTORY_* 库存上沿（可选）
# DATA_DIR=./data
# DASHBOARD_API_KEY=

# --- 详细离线日志（按日 JSONL，见 data/logs/daily/YYYY-MM-DD/）---
# DETAILED_DAILY_LOG=1
# 启动时删除 data/logs 根下旧 *.log / quant.log.* / live_*.log（不动 daily/ 与 audit.sqlite3）
# DETAILED_LOG_PURGE_LEGACY=1
# market.jsonl 最小写入间隔（秒），0=每笔 tick 都写（体积大）
# DETAILED_LOG_TICK_MIN_SEC=0
